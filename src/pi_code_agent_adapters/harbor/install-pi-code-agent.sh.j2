#!/bin/bash
set -euo pipefail

if ! command -v python3 >/dev/null 2>&1; then
  if ! command -v apt-get >/dev/null 2>&1; then
    echo "python3 is required but apt-get is unavailable" >&2
    exit 1
  fi
  apt-get update
  apt-get install -y python3 python3-pip
fi

if ! python3 -m pip --version >/dev/null 2>&1; then
  if command -v apt-get >/dev/null 2>&1; then
    apt-get update
    apt-get install -y python3-pip
  else
    python3 -m ensurepip --upgrade
  fi
fi

python3 -m pip install --upgrade pip
python3 -m pip install /installed-agent/pi-code-agent

python3 -m pi_code_agent --help >/dev/null
python3 -m pi_code_agent_adapters.bench.exec_prompt --help >/dev/null
