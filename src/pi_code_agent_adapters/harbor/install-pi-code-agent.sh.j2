#!/bin/bash
set -euo pipefail

PACKAGE_ROOT=/installed-agent/pi-code-agent
VENV_PATH="$PACKAGE_ROOT/.venv"
VENV_PYTHON="$VENV_PATH/bin/python"

if ! command -v python3 >/dev/null 2>&1; then
  if ! command -v apt-get >/dev/null 2>&1; then
    echo "python3 is required but apt-get is unavailable" >&2
    exit 1
  fi
  apt-get update
  apt-get install -y python3 python3-venv
fi

if ! python3 -m venv --help >/dev/null 2>&1; then
  if command -v apt-get >/dev/null 2>&1; then
    apt-get update
    apt-get install -y python3-venv
  else
    echo "python3 venv support is required but unavailable" >&2
    exit 1
  fi
fi

python3 -m venv "$VENV_PATH"
"$VENV_PYTHON" -m pip install --upgrade pip
"$VENV_PYTHON" -m pip install "$PACKAGE_ROOT"

"$VENV_PYTHON" -m pi_code_agent --help >/dev/null
"$VENV_PYTHON" -m pi_code_agent_adapters.bench.exec_prompt --help >/dev/null
