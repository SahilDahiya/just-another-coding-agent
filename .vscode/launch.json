{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: JACA Backend (headless RPC)",
            "type": "debugpy",
            "request": "launch",
            "module": "just_another_coding_agent",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1",
                "JACA_TRACE_MODE": "local"
            },
            "args": [
                "--headless",
                "--model",
                "${input:jacaModel}",
                "--workspace-root",
                "${workspaceFolder}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Pytest Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "${file}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Pytest Current Test (-k)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "${file}",
                "-k",
                "${input:pytestFilter}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: RPC stdio e2e",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "tests/e2e/test_stdio_server.py"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Compaction stress e2e",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "tests/e2e/test_compaction_stress.py"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ],
    "inputs": [
        {
            "id": "jacaModel",
            "type": "promptString",
            "description": "Model id for the headless backend",
            "default": "openai:gpt-5.4"
        },
        {
            "id": "pytestFilter",
            "type": "promptString",
            "description": "pytest -k expression for the current file",
            "default": "test_"
        }
    ]
}
