{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Go: RPC types current package test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}",
            "args": [
                "-test.run",
                "^${input:goTestName}$"
            ],
            "dlvToolPath": "/home/dahiy/go/bin/dlv",
            "showLog": true
        },
        {
            "name": "Python: JACA Backend (headless RPC)",
            "type": "debugpy",
            "request": "launch",
            "module": "just_another_coding_agent",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1",
                "JACA_TRACE_MODE": "local"
            },
            "args": [
                "--headless",
                "--model",
                "${input:jacaModel}",
                "--workspace-root",
                "${workspaceFolder}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: JACA Backend one prompt",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/debug_rpc_once.py",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1",
                "JACA_TRACE_MODE": "local"
            },
            "args": [
                "--model",
                "${input:jacaModel}",
                "--prompt",
                "${input:jacaPrompt}",
                "--workspace-root",
                "${workspaceFolder}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: JACA Backend prompt sequence",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/debug_rpc_once.py",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1",
                "JACA_TRACE_MODE": "local"
            },
            "args": [
                "--model",
                "${input:jacaModel}",
                "--prompts",
                "${input:jacaPrompts}",
                "--workspace-root",
                "${workspaceFolder}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Pytest Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "${file}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Pytest Current Test (-k)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "${file}",
                "-k",
                "${input:pytestFilter}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: RPC stdio e2e",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "tests/e2e/test_stdio_server.py"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Compaction stress e2e",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTHONUNBUFFERED": "1"
            },
            "args": [
                "-q",
                "tests/e2e/test_compaction_stress.py"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ],
    "inputs": [
        {
            "id": "jacaModel",
            "type": "promptString",
            "description": "Model id for the headless backend",
            "default": "openai-responses:gpt-5.4"
        },
        {
            "id": "goTestName",
            "type": "promptString",
            "description": "Exact Go test name for -test.run",
            "default": "TestDecodeEnvelopePreservesRunSucceededUsageFields"
        },
        {
            "id": "pytestFilter",
            "type": "promptString",
            "description": "pytest -k expression for the current file",
            "default": "test_"
        },
        {
            "id": "jacaPrompt",
            "type": "promptString",
            "description": "Prompt for one-shot backend debugging",
            "default": "hello"
        },
        {
            "id": "jacaPrompts",
            "type": "promptString",
            "description": "Prompt sequence for the same session, separated by ||",
            "default": "hello || run some tests || summarize what happened"
        }
    ]
}
